{
  "name": "agentos",
  "version": "0.1.3",
  "description": "AgentOS - AI Agent development platform",
  "author": "Agent Harness Team",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit",
    "lint": "eslint electron/ src/ shared/ --ext .ts,.tsx",
    "lint:fix": "eslint electron/ src/ shared/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"electron/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" \"shared/**/*.ts\"",
    "format:check": "prettier --check \"electron/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" \"shared/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.4",
    "chokidar": "^3.5.3",
    "discord.js": "^14.26.4",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "i18next": "^26.3.1",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "systeminformation": "^5.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@rollup/rollup-win32-x64-msvc": "^4.60.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^28.3.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0"
  }
}
