{
  "appId": "com.agentos.desktop",
  "productName": "AgentOS",
  "asar": false,
  "publish": {
    "provider": "github",
    "owner": "zorrokurro",
    "repo": "agent-os"
  },
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron",
    "dist-renderer",
    "public",
    "agents-registry.json",
    "node_modules/sql.js/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "artifactName": "AgentOS-${version}-Setup.${ext}"
  },
  "buildNumber": 1
}
